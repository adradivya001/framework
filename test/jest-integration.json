{
    "rootDir": "..",
    "testMatch": [
        "<rootDir>/test/**/*.integration.spec.ts",
        "<rootDir>/test/**/*.e2e*.spec.ts",
        "<rootDir>/test/**/e2e-*.spec.ts"
    ],
    "transform": {
        "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleFileExtensions": [
        "js",
        "json",
        "ts"
    ],
    "testEnvironment": "node",
    "testTimeout": 120000,
    "forceExit": true,
    "detectOpenHandles": false,
    "globals": {
        "ts-jest": {
            "tsconfig": "<rootDir>/tsconfig.json"
        }
    },
    "moduleNameMapper": {
        "^uuid$": "<rootDir>/node_modules/uuid/dist/cjs/index.js"
    }
}